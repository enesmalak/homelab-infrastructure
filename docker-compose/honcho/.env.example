# Honcho configuration. Copy to .env and fill in.

# Postgres DSN — matches the bundled database service
DB_CONNECTION_URI=postgresql+psycopg://postgres:postgres@database:5432/postgres

# LLM provider (OpenAI-compatible endpoint; I point this at DeepSeek)
LLM_OPENAI_API_KEY=your-llm-api-key-here

# Vector store
VECTOR_STORE_TYPE=pgvector
VECTOR_STORE_MIGRATED=true

# Set true and configure auth before exposing the API beyond localhost
AUTH_USE_AUTH=false

LOG_LEVEL=INFO
