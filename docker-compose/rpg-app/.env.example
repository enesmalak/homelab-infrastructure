# RPG App configuration. Copy to .env and fill in.

# --- App auth ---
APP_PASSWORD=change-me                       # gate for the web UI
SECRET_KEY=change-me-to-a-long-random-string # session signing

# --- Honcho (self-hosted memory backend) ---
HONCHO_API_KEY=your-honcho-api-key-here

# --- LLM providers (set only the ones you use) ---
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Narration vs. background/utility model split
BACKGROUND_MODEL=deepseek-chat

# --- Local models via Ollama (optional) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
