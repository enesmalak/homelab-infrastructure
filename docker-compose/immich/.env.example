# Pin a specific release for reproducible upgrades (e.g. v1.106.4)
IMMICH_VERSION=release

# Postgres connection (consumed by both the server and the database container)
DB_HOSTNAME=immich-postgres
DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_PASSWORD=change-me-to-a-strong-password

# Signing secret for user sessions — generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

TZ=Europe/Berlin
